---
# ============================================================
# VAULT EXAMPLE (encrypt this file with ansible-vault)
#
# Usage:
#   cp ansible/group_vars/all/vault.yml.example ansible/group_vars/all/vault.yml
#   ansible-vault encrypt ansible/group_vars/all/vault.yml
#   ansible-playbook ... --ask-vault-pass
#
# Keep ALL secrets here (WireGuard keys, Authelia secrets, Agent Zero passwords).
# ============================================================

# ------------------------------------------------------------
# WireGuard
#
# Recommended: let the wireguard role generate peer keypairs automatically
# (omit private_key/public_key below) and it will fetch ready-to-import
# client configs to ansible/artifacts/wireguard/*.conf.
#
# If you prefer to BYO keys, put them here.
# ------------------------------------------------------------

wireguard_endpoint: "vpn.example.com:51820"

# Lightsail note:
# Lightsail SSH keys are often managed per-zone. A cleaner workflow is:
#   1) Bring up WireGuard
#   2) Restrict SSH to VPN subnet (set wireguard_restrict_ssh_to_vpn: true)
#   3) Use your own long-lived SSH key(s) on all laptops
# This avoids juggling zone-specific keys when switching devices.

# wireguard_restrict_ssh_to_vpn: true

wireguard_peers: []
#  - name: laptop_student_1
#    allowed_ips: "10.8.0.10/32"
    # Optional (BYO keys):
    # private_key: "<client_private_key>"
    # public_key: "<client_public_key>"
#  - name: laptop_student_2
#    allowed_ips: "10.8.0.11/32"

# ------------------------------------------------------------
# Authelia
# ------------------------------------------------------------

# Public/auth portal domain (must resolve to your edge gateway)
authelia_domain: "auth.example.com"

authelia_jwt_secret: "CHANGE_ME_LONG_RANDOM"
authelia_session_secret: "CHANGE_ME_LONG_RANDOM"
# Must be >= 32 chars (Authelia requirement)
authelia_storage_encryption_key: "CHANGE_ME_32_CHARS_MINIMUM________"

# Authelia users (passwords should be pre-hashed)
# Generate hashes with:
#   docker run --rm authelia/authelia:latest authelia crypto hash generate argon2 --password 'YourPass'
authelia_users:
  - username: alice
    displayname: Alice
    email: alice@example.com
    password_hash: "$argon2id$..."
    groups: ["a0_users"]
  - username: bob
    displayname: Bob
    email: bob@example.com
    password_hash: "$argon2id$..."
    groups: ["a0_users"]

# ------------------------------------------------------------
# Agent Zero (per-user)
# ------------------------------------------------------------

agent_zero_users:
  - username: alice
    domain: "alice.a0.example.com"
    auth_login: "alice"
    auth_password: "CHANGE_ME_STRONG_PASSWORD"
  - username: bob
    domain: "bob.a0.example.com"
    auth_login: "bob"
    auth_password: "CHANGE_ME_STRONG_PASSWORD"


# ------------------------------------------------------------
# CoreDNS / internal DNS over WireGuard
# ------------------------------------------------------------
# Tell WireGuard clients to use the VPN DNS resolver at 10.8.0.1.
# After enabling this, internal app domains can resolve to the edge gateway
# over the tunnel without hosts-file edits.
#
# coredns_static_domains:
#   - "cgs.unifypesacard.shop"
#   - "auth.unifypesacard.shop"
#   - "vscode.unifypesacard.shop"
# coredns_wildcard_zones:
#   - "dev.unifypesacard.shop"
#   - "a0.unifypesacard.shop"

# ------------------------------------------------------------
# VS Code (per-user)
# ------------------------------------------------------------
# Multi-tenant code-server: one container per user.
# Domains under *.dev.example.com work automatically with CoreDNS wildcard mode.
#
# vscode_default_domain_suffix: "dev.example.com"
vscode_users:
  - username: alice
    domain: "alice.dev.example.com"
    password: "CHANGE_ME_STRONG_PASSWORD"
  - username: bob
    domain: "bob.dev.example.com"
    password: "CHANGE_ME_STRONG_PASSWORD"
