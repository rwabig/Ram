version: "3.9"

services:
{% if vscode_users | length > 0 %}
{% for user in vscode_users %}
  vscode-{{ user.username }}:
    image: codercom/code-server:latest
    container_name: vscode-{{ user.username }}
    restart: unless-stopped

    command: >
      code-server
      --bind-addr 0.0.0.0:{{ vscode_port }}
      --auth password
      /home/coder/project

    environment:
      PASSWORD: "{{ user.password | default(vscode_default_password) }}"

    volumes:
      - ./{{ user.username }}/workspace:/home/coder/project
      - ./{{ user.username }}/config:/home/coder/.local/share/code-server

    networks:
      - {{ edge_gateway_network }}

    labels:
      edge.enable: "true"
      edge.port: "{{ vscode_port }}"
{% if user.domain is defined and user.domain | length > 0 %}
      edge.domain: "{{ user.domain }}"
{% else %}
      edge.tenant: "{{ user.username }}"
      edge.class: "dev"
{% endif %}
{% if vscode_enable_edge_auth | bool %}
      edge.auth: "authelia"
{% endif %}

{% endfor %}
{% else %}
  vscode:
    image: codercom/code-server:latest
    container_name: {{ vscode_container_name }}
    restart: unless-stopped

    command: >
      code-server
      --bind-addr 0.0.0.0:{{ vscode_port }}
      --auth none
      /home/coder/project

    volumes:
      - ./vscode/workspace:/home/coder/project
      - ./vscode/config:/home/coder/.local/share/code-server

    networks:
      - {{ edge_gateway_network }}

    labels:
      edge.enable: "true"
      edge.port: "{{ vscode_port }}"
{% if vscode_domain is defined and vscode_domain | length > 0 %}
      edge.domain: "{{ vscode_domain }}"
{% else %}
      edge.tenant: "default"
      edge.class: "dev"
{% endif %}
{% endif %}

networks:
  {{ edge_gateway_network }}:
    external: true
