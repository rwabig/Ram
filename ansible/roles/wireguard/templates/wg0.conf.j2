[Interface]
Address = {{ wireguard_address }}
ListenPort = {{ wireguard_port }}
PrivateKey = {{ wireguard_server_private_key }}

# Enable forwarding/NAT outside of this role if you need full-tunnel.

{% for peer in (wireguard_peers_resolved | default(wireguard_peers)) %}
[Peer]
# {{ peer.name }}
PublicKey = {{ peer.public_key }}
AllowedIPs = {{ peer.allowed_ips }}

{% endfor %}
